COMPONENT=TCPEchoC
TINYOS_ROOT_DIR?=../..

# Same IPv6 prefix as the border router.
CFLAGS += -DIN6_PREFIX=\"fd00:23:42:1::\"
CFLAGS += -DCC2420_DEF_CHANNEL=26
CFLAGS += -DCC2420_DEF_RFPOWER=31
DEFAULT_LOCAL_GROUP = 0xCA
CFLAGS += -DBLIP_ADDR_AUTOCONF=0
CFLAGS += -DRPL_ADDR_AUTOCONF=0
CFLAGS += -DRPL_ROUTING=1
CFLAGS += -DLIB6LOWPAN_HC_VERSION=6

# End node: solicit router, do not advertise as router.
CFLAGS += -DBLIP_SEND_ROUTER_SOLICITATIONS=1
CFLAGS += -DBLIP_SEND_ROUTER_ADVERTISEMENTS=0

# TCP echo port.
CFLAGS += -DTCP_ECHO_PORT=7

GOALS += blip rpl

include $(TINYOS_ROOT_DIR)/Makefile.include
